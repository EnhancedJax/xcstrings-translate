{
  "name": "xcstrings-translate",
  "version": "1.0.0",
  "description": "CLI util to machine translate xcstrings using Copilot",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "xct": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "xcstrings",
    "localization",
    "swift",
    "xcode",
    "ios",
    "machine-translation",
    "copilot",
    "csv",
    "translation",
    "cli"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --out-dir dist --clean --target node18",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun run test && bun run build",
    "prepack": "npm run build",
    "xct": "node dist/cli.js"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "opencc-js": "^1.0.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}